---
import refsData from '../data/bibliography.json';

interface Ref {
  author_last: string;
  author_first: string;
  title: string;
  translator?: string;
  publisher: string;
  location: string;
  year: number;
  category: string;
}

const refs = refsData as Ref[];

const sorted = [...refs].sort((a, b) =>
  a.author_last.localeCompare(b.author_last)
);

const grouped = sorted.reduce((acc: Record<string, Ref[]>, ref: Ref) => {
  if (!acc[ref.category]) acc[ref.category] = [];
  acc[ref.category].push(ref);
  return acc;
}, {});

const categoryOrder = [
  "Philosophy",
  "Psychology and Consciousness",
  "Sociology and Civilization",
  "Architecture and Space",
  "Culture and Media"
];

const categories = categoryOrder.filter(c => grouped[c]);
---

{categories.map(category => (
  <section>
    <h2>{category}</h2>
    {grouped[category].map(ref => (
      <p class="bibliography-entry">
        {ref.author_last}, {ref.author_first}.
        <em> {ref.title}</em>.
        {ref.translator && ` Translated by ${ref.translator}.`}
        {' '}{ref.location}: {ref.publisher}, {ref.year}.
      </p>
    ))}
  </section>
))}